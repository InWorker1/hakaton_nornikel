# ════════════════════════════════════════════════════════════════════════════
# .env.example — ШАБЛОН переменных окружения.
#
# Использование:
#   cp .env.example .env       ← скопировать и заполнить реальными значениями
#   chmod 600 .env             ← ограничить доступ (только владелец)
#
# Никогда не коммитьте .env в git! Файл .env должен оставаться локальным.
# См. SECRETS.md для подробностей.
# ════════════════════════════════════════════════════════════════════════════

# ───────────── LLM (п.5 плана: NL→Cypher, синтез ответа) ─────────────
# Какой провайдер используется — OpenAI, Anthropic, локальный или
# совместимый endpoint. Ключ хранится в LLM_API_KEY.
# Можно задать ОБА ключа (OpenAI и Anthropic) и в коде выбирать по
# LLM_PROVIDER. Совместимые с OpenAI эндпоинты (vLLM, OpenRouter,
# локальный Ollama через /v1) — тоже подходят, тогда меняется
# LLM_BASE_URL.

# LLM_PROVIDER=openai           # openai | anthropic | openai_compat | ollama
# LLM_API_KEY=sk-...            # <-- ВСТАВЬ СВОЙ КЛЮЧ В .env
# LLM_MODEL=gpt-4o-mini         # модель по умолчанию
# LLM_BASE_URL=                 # для openai_compat / ollama
# LLM_TEMPERATURE=0.0           # NL→Cypher лучше при 0
# LLM_MAX_TOKENS=2048

# ───────────── Neo4j (п.4 плана: граф знаний) ─────────────
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=               # <-- ВСТАВЬ СВОЙ ПАРОЛЬ В .env
# NEO4J_DATABASE=neo4j          # имя БД (по умолчанию neo4j)

# ───────────── Полнотекстовый движок (п.5, опционально) ─────────────
# Можно держать Elasticsearch для семантического поиска. Если не нужен —
# оставьте пустым, и движок не стартует.
#
# SEARCH_ENGINE=                # elasticsearch | vespa | none
# ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=

# ───────────── Аналитика / логирование ─────────────
# Отправлять ли в облако (Sentry / Langfuse) только при необходимости.
#
# LOG_LEVEL=INFO
# SENTRY_DSN=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# ───────────── Конфигурация ролей / доступа (п.9 плана) ─────────────
# JWT_SECRET=                   # <-- ВСТАВЬ СВОЙ В .env (>= 32 символов)
# JWT_ALGORITHM=HS256
# JWT_EXPIRES_MIN=60

# ───────────── Endpoints исходных данных ─────────────
# Хакатонский Я.Диск. Может быть публичным или требовать токен.
# YANDEX_DISK_URL=https://disk.yandex.ru/d/npigiuw4Rbe9Pg
# YANDEX_DISK_PUBLIC_TOKEN=
